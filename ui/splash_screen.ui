  <property name="styleSheet">
   <string notr="true">
/* ---- Splash Screen overall background ---- */
QWidget#SplashScreenClass {
    background-color: #1e1e2e;
    border-radius: 12px;
    border: 1px solid #313244;
}

/* ---- App title label ---- */
QLabel#titleLabel {
    color: #cdd6f4;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    font-size: 26px;
    font-weight: bold;
    letter-spacing: 2px;
}

/* ---- Subtitle / version label ---- */
QLabel#subtitleLabel {
    color: #a6adc8;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    font-size: 12px;
}

/* ---- Status text ---- */
QLabel#statusLabel {
    color: #89b4fa;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    font-size: 12px;
}

/* ---- Percent label ---- */
QLabel#percentLabel {
    color: #a6e3a1;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    font-size: 12px;
    font-weight: bold;
}

/* ---- Progress bar ---- */
QProgressBar {
    background-color: #313244;
    border: none;
    border-radius: 5px;
    height: 10px;
    text-align: center;
    color: transparent;
}
QProgressBar::chunk {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #89b4fa, stop:1 #a6e3a1);
    border-radius: 5px;
}
   </string>
